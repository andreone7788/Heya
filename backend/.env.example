# Database
DATABASE_URL="mysql://user:password@localhost:3306/heya_db"

# Sessioni e Sicurezza
SESSION_SECRET="your_super_secret_session_key_here_change_this"
ENCRYPTION_KEY="generate_with_node_crypto_randomBytes_32_toString_hex"

# Ambiente
NODE_ENV="development"

# Configurazione Mail (Gmail)
MAIL_HOST="smtp.gmail.com"
MAIL_PORT="587"
MAIL_SECURE="false"
MAIL_USER="your-email@gmail.com"
MAIL_PASS="your-app-specific-password"
MAIL_FROM="Heya <your-email@gmail.com>"

# Admin
ADMIN_EMAIL="admin@example.com"
